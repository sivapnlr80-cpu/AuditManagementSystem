# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Force bash scripts/files to keep LF (Unix) line endings
*.sh text eol=lf

# Force batch/powershell files to keep CRLF (Windows) line endings
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.exe binary
